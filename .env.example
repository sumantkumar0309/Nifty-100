# Warehouse PostgreSQL connection string (used by ETL and scoring)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/nifty100_warehouse
WAREHOUSE_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/nifty100_warehouse

# Django settings
DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Redis + Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TIMEZONE=Asia/Kolkata

# HMAC key encryption for partner API keys (must be a valid Fernet key)
# Example generation: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_SECRET_ENCRYPTION_KEY=replace-with-generated-fernet-key

# ============================================================================
# BACKEND 2: CELERY, CACHING, AND API AUTHENTICATION
# ============================================================================

# ETL Module Configuration
ETL_IMPORT_MODULE=etl.00_import_marketai_data
ETL_EXTRACT_SQL_MODULE=etl.01_extract_from_mysql
ETL_TRANSFORM_MODULE=etl.02_clean_and_transform
ETL_LOAD_MODULE=etl.03_load_to_warehouse
ML_REFRESH_MODULE=etl.04_generate_ml_scores

# ETL Pipeline Scheduling
ETL_DAILY_HOUR=1
ETL_DAILY_MINUTE=0
ETL_WEEKLY_DAY_OF_WEEK=sun
ETL_WEEKLY_HOUR=3
ETL_WEEKLY_MINUTE=0

# Cache Configuration
CACHE_PATTERNS=company_profile:*,financial_trend:*,dashboard_summary:*,health_scores:*
CACHE_DEFAULT_TTL=3600
CACHE_COMPANY_DETAIL_TTL=1800
CACHE_SECTOR_LIST_TTL=7200

# Logging Configuration
BACKEND2_LOG_LEVEL=INFO
BACKEND2_LOG_FILE=./orchestration/backend2/logs/backend2.log

# Webhook Configuration
WEBHOOK_TIMEOUT_SECONDS=20
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_BACKOFF_SECONDS=30

# API Rate Limiting
API_RATE_LIMIT_REQUESTS_PER_MINUTE=60
API_RATE_LIMIT_BURST=20

