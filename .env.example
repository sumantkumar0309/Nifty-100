# PostgreSQL warehouse connection
WAREHOUSE_DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/nifty100

# Input SQL dump path (MariaDB export)
NIFTY_SQL_DUMP_PATH=./data/source/scriptticker.sql

# Optional: Use already-cleaned marketAI CSV dataset as ETL source
MARKETAI_DATA_DIR=./marketAI/data

# Row chunk size for upserts
ETL_BATCH_SIZE=1000
