# ============================================================================
# NIFTY 100 FINANCIAL INTELLIGENCE SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================================

# ============================================================================
# DJANGO CONFIGURATION
# ============================================================================
DEBUG=false
DJANGO_SETTINGS_MODULE=backend2.settings
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_PORT=8000

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nifty100_warehouse
DB_USER=nifty100
DB_PASSWORD=change_this_secure_password_in_production
DATABASE_URL=postgresql://nifty100:change_this_secure_password_in_production@postgres:5432/nifty100_warehouse
WAREHOUSE_DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/nifty100

# ============================================================================
# REDIS CONFIGURATION (Cache & Message Broker)
# ============================================================================
REDIS_URL=redis://:redis_secure_pass@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass
REDIS_DB=0

# ============================================================================
# CELERY CONFIGURATION (Background Task Processing)
# ============================================================================
CELERY_BROKER_URL=redis://:redis_secure_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secure_pass@redis:6379/2
CELERY_TIMEZONE=Asia/Kolkata
CELERY_BEAT_CRON=true

# ETL Pipeline Scheduling
ETL_DAILY_HOUR=1
ETL_DAILY_MINUTE=0
ETL_WEEKLY_DAY_OF_WEEK=sun
ETL_WEEKLY_HOUR=3
ETL_WEEKLY_MINUTE=0

# ============================================================================
# ETL MODULE CONFIGURATION
# ============================================================================
ETL_IMPORT_MODULE=etl.00_import_marketai_data
ETL_EXTRACT_SQL_MODULE=etl.01_extract_from_mysql
ETL_TRANSFORM_MODULE=etl.02_clean_and_transform
ETL_LOAD_MODULE=etl.03_load_to_warehouse
ML_REFRESH_MODULE=etl.04_generate_ml_scores
PYTHON_EXECUTABLE=python

# Input SQL dump path (MariaDB export)
NIFTY_SQL_DUMP_PATH=./data/source/scriptticker.sql

# Optional: Use already-cleaned marketAI CSV dataset as ETL source
MARKETAI_DATA_DIR=./marketAI/data

# Row chunk size for upserts
ETL_BATCH_SIZE=1000

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
CACHE_PATTERNS=company_profile:*,financial_trend:*,dashboard_summary:*,health_scores:*
CACHE_DEFAULT_TTL=3600
CACHE_COMPANY_DETAIL_TTL=1800
CACHE_SECTOR_LIST_TTL=7200

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
BACKEND2_LOG_LEVEL=INFO
BACKEND2_LOG_FILE=./marketAI/backend/backend2/logs/backend2.log

# ============================================================================
# WEBHOOK CONFIGURATION
# ============================================================================
WEBHOOK_TIMEOUT_SECONDS=20
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_BACKOFF_SECONDS=30

# ============================================================================
# API RATE LIMITING
# ============================================================================
API_RATE_LIMIT_REQUESTS_PER_MINUTE=60
API_RATE_LIMIT_BURST=20

# ============================================================================
# NGINX CONFIGURATION
# ============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ============================================================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================================================
SENTRY_DSN=
DATADOG_API_KEY=
NEWRELIC_LICENSE_KEY=

# ============================================================================
# SECURITY HEADERS & SSL
# ============================================================================
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# ============================================================================
# OPTIONAL: DEPLOYMENT & CI/CD
# ============================================================================
DEPLOY_ENVIRONMENT=production
CI_BRANCH=main
CI_COMMIT_SHA=
GITHUB_TOKEN=
